# BuildForge Agents — owner machine defaults (Windows + Ollama Bonsai)
# Copy to .env or set in system env. All optional.

BUILDFORGE_MODE=neural
BUILDFORGE_LLM=ollama
BUILDFORGE_MODEL=hf.co/prism-ml/Bonsai-8B-gguf:Q1_0
BUILDFORGE_MODEL_LIGHT=hf.co/prism-ml/Bonsai-1.7B-gguf:Q1_0
BUILDFORGE_OLLAMA_URL=http://127.0.0.1:11434
BUILDFORGE_MAX_FIX_RETRIES=2
BUILDFORGE_PHONE_PORT=8787

# Anti-freeze / anti-hang (hard caps)
BUILDFORGE_GUARD_ENABLED=1
BUILDFORGE_CPU_CRITICAL=97
BUILDFORGE_RAM_CRITICAL=96
BUILDFORGE_CPU_RECOVER=90
BUILDFORGE_RAM_RECOVER=90
BUILDFORGE_GUARD_POLL=0.75
BUILDFORGE_GUARD_MAX_WAIT=180
BUILDFORGE_GUARD_BASE_PAUSE=1.0
BUILDFORGE_GUARD_MAX_PAUSE=12
BUILDFORGE_GUARD_LOW_PRIORITY=1
